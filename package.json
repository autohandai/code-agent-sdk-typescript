{
  "name": "@autohand/agent-sdk",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Autohand Code Agent SDK - CLI wrapper implementation",
  "repository": {
    "type": "git",
    "url": "https://github.com/autohandai/code-agent-sdk-typescript"
  },
  "homepage": "https://autohand.ai/sdk/",
  "bugs": {
    "url": "https://github.com/autohandai/code-agent-sdk-typescript/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/__tests__",
    "cli",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "bun test src/__tests__",
    "test:examples": "bun run examples/test-examples.ts",
    "build:example:structured-json": "bun build examples/25-structured-json.ts --outdir /private/tmp/autohand-sdk-example-25-check --target=node",
    "build:examples": "bun build examples/*.ts --outdir /private/tmp/autohand-sdk-all-example-check --target=node",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build && bun run lint"
  },
  "keywords": [
    "sdk",
    "llm",
    "agent",
    "autohand",
    "cli-wrapper"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
