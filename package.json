{
  "name": "@autohandai/agent-sdk",
  "version": "1.0.3",
  "license": "Apache-2.0",
  "description": "Autohand Code Agent SDK - CLI wrapper implementation",
  "repository": {
    "type": "git",
    "url": "https://github.com/autohandai/code-agent-sdk-typescript"
  },
  "homepage": "https://autohand.ai/sdk/",
  "bugs": {
    "url": "https://github.com/autohandai/code-agent-sdk-typescript/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/__tests__",
    "cli",
    "README.md",
    "CHANGELOG.md",
    "docs/autoresearch.md",
    "docs/reliability-and-performance.md",
    "scripts/benchmark-startup.mjs",
    "examples/27-autoresearch-ledger.ts",
    "tsconfig.examples.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "lint": "eslint src --ext .ts",
    "test": "bun test src/__tests__",
    "test:examples": "bun run examples/test-examples.ts",
    "benchmark:startup": "bun run build && node scripts/benchmark-startup.mjs",
    "build:example:structured-json": "node scripts/build-examples.mjs examples/25-structured-json.ts",
    "build:examples": "node scripts/build-examples.mjs",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build && bun run typecheck:examples && bun run test:examples && bun run build:examples && bun run lint"
  },
  "keywords": [
    "sdk",
    "llm",
    "agent",
    "autohand",
    "cli-wrapper"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "toml": "^4.1.1",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
